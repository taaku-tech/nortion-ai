# ─── Supabase PostgreSQL ──────────────────────────────────────────────────────
# Vercel Function 用（Transaction Pooler, port 6543）
# prepare: false が必須（pgBouncer Transaction mode）
DATABASE_URL=your_database_url

# drizzle-kit migrate 用（Direct Connection, port 5432）
DATABASE_URL_DIRECT=your_database_url_direct

# ─── Notion ───────────────────────────────────────────────────────────────────
NOTION_TOKEN=your_notion_token_here
NOTION_DATABASE_ID=your_notion_database_id
# DBの日付プロパティ名（未設定時は "日付"。空文字にするとsort無効化）
NOTION_DATE_PROPERTY=日時

# ─── Gemini ───────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# ─── Vercel Cron ──────────────────────────────────────────────────────────────
# openssl rand -hex 32 で生成してください
CRON_SECRET=your_random_secret_here

# ─── 管理画面簡易保護 ─────────────────────────────────────────────────────────
# /admin?key=xxx / /search?key=xxx のアクセスキー
# openssl rand -hex 32 で生成してください
ADMIN_SECRET=your_admin_secret_here

# ─── メール通知（任意・未設定時は送信スキップ） ───────────────────────────────
# Resend（https://resend.com）で取得した API キー
RESEND_API_KEY=
# サマリメールの送信先・送信元アドレス
OPS_SUMMARY_EMAIL_TO=
# 送信元は Resend で検証済みのドメインのアドレスを使用してください
OPS_SUMMARY_EMAIL_FROM=

# ─── 処理設定（任意・デフォルト値あり） ──────────────────────────────────────
BATCH_SIZE=10
SLEEP_MS=1000
ZOMBIE_TIMEOUT_MIN=15
NOTION_API_VERSION=2022-06-28
